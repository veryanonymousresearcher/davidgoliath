    "  \"BPI20_001\",\n",
    "  \"BPI20_002\",\n",
    "  \"GPT2-small-mini-all_001\",   #not complete yet\n",
    "]\n",
    "\n",
    "runs_raw, _ = load_multiple_experiments(PROJECTS, force_update=False)\n"
   ]
